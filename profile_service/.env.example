# profile_service Configuration Template
DEBUG=True
SECRET_KEY=django-insecure-profile-dev-key
JWT_SECRET_KEY=shared-jwt-secret-key-12345
DB_HOST=db
DB_PORT=5432
DB_PASSWORD=postgres123

# Redis Cache and Celery Broker Settings
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
