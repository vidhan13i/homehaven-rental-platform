# ==============================================================================
# Microservices Platform — Master Configuration Template (.env.example)
# Copy this file to '.env' in the root directory and update the values.
# ==============================================================================

# ─── GENERAL SETTINGS ─────────────────────────────────────────────────────────
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,gateway,profile_service,auth_service,listings_service,application_service,building_service,reviews_service

# ─── SECURITY SECRETS (REQUIRED) ──────────────────────────────────────────────
# Django signing secret key
SECRET_KEY=django-insecure-master-secret-key-change-in-production

# Shared JWT signing key for stateless token validation
JWT_SECRET_KEY=shared-jwt-secret-key-12345-change-in-production

# ─── DATABASE CREDENTIALS (REQUIRED) ──────────────────────────────────────────
# PostgreSQL database settings
DB_HOST=db
DB_PORT=5432
DB_PASSWORD=postgres123

# ─── CACHE & MESSAGE BROKER (REDIS) ───────────────────────────────────────────
# Redis connection settings (used by profile_service and celery_worker)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── EMAIL SETTINGS (OPTIONAL FOR DEV) ────────────────────────────────────────
# Console backend prints emails to stdout; use SMTP backend in production
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password
DEFAULT_FROM_EMAIL=Haven Rentals <noreply@haven.local>
